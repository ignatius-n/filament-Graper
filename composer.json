{
    "name": "cybertroniankelvin/graper",
    "description": "A visual drag-and-drop page builder for Filament admin panels, powered by GrapeJS v3. Build landing pages, marketing sites, and custom content pages without writing code.",
    "keywords": [
        "filament",
        "laravel",
        "grapejs",
        "page-builder",
        "cms",
        "drag-and-drop",
        "visual-editor",
        "admin"
    ],
    "homepage": "https://github.com/cybertroniankelvin/graper",
    "license": "MIT",
    "authors": [
        {
            "name": "Kelvin Atawura",
            "email": "katawura@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CybertronianKelvin\\Graper\\": "src/",
            "CybertronianKelvin\\Graper\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CybertronianKelvin\\Graper\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": [
            "@php vendor/bin/testbench package:discover --ansi || true"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CybertronianKelvin\\Graper\\GraperServiceProvider"
            ],
            "aliases": {
                "Graper": "CybertronianKelvin\\Graper\\Facades\\Graper"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}